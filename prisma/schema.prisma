generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeliveryReport {
  id         String          @id @default(cuid())
  filename   String
  uploadedAt DateTime        @default(now())
  isActive   Boolean         @default(true)
  orders     DeliveryOrder[]
}

model ScheduledReport {
  id           String        @id @default(cuid())
  reportId     String
  emails       String
  frequency    String
  time         String
  dayOfWeek    Int?
  dayOfMonth   Int?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sendLogs     EmailSendLog[]
}

model EmailSendLog {
  id          String          @id @default(cuid())
  scheduleId  String
  schedule    ScheduledReport @relation(fields: [scheduleId], references: [id])
  sentAt      DateTime        @default(now())
  success     Boolean
  recipients  String
  error       String?
}

// ─── ALERTES & TICKETS ─────────────────────────────────────────────────────

model AlertRule {
  id        String   @id @default(cuid())
  name      String
  metric    String   // "delivery_rate" | "no_show_rate" | "on_time_rate" | "no_show_count"
  operator  String   // "lt" | "gt" | "lte" | "gte"
  threshold Float
  severity  String   @default("warning") // "critical" | "warning" | "info"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  alerts    Alert[]
}

model Alert {
  id          String    @id @default(cuid())
  ruleId      String?
  rule        AlertRule? @relation(fields: [ruleId], references: [id])
  type        String    // "auto" | "manual"
  severity    String    // "critical" | "warning" | "info"
  title       String
  description String
  metricValue Float?
  threshold   Float?
  status      String    @default("open") // "open" | "in_progress" | "resolved"
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  tickets     Ticket[]
}

model Ticket {
  id          String          @id @default(cuid())
  alertId     String?
  alert       Alert?          @relation(fields: [alertId], references: [id])
  title       String
  description String
  priority    String          @default("moyenne") // "haute" | "moyenne" | "basse"
  status      String          @default("ouvert") // "ouvert" | "en_cours" | "resolu" | "ferme"
  assignedTo  String?
  comments    TicketComment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    String
  content   String
  createdAt DateTime @default(now())
}

// ─── DELIVERY ORDERS ───────────────────────────────────────────────────────

model DeliveryOrder {
  id                          String         @id @default(cuid())
  reportId                    String
  report                      DeliveryReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  externalReference           String?
  shipperReference            String?
  carrierReference            String?

  pickupTimeStart             DateTime?
  deliveryTimeStart           DateTime?
  deliveryTimeEnd             DateTime?

  dateTimeWhenOrderSent       DateTime?
  dateTimeWhenAssigned        DateTime?
  dateTimeWhenInTransport     DateTime?
  dateTimeWhenStartDelivery   DateTime?
  dateTimeWhenDelivered       DateTime?
  dateTimeWhenNoShow          DateTime?
  dateTimeLastUpdate          DateTime?

  shippingWorkflowStatus      String?
  paymentOnDeliveryAmount     Float?

  destinationFirstname        String?
  destinationLastname         String?
  destinationCityCode         String?
  destinationLongitude        Float?
  destinationLatitude         Float?

  originHubName               String?
  originHubCode               String?
  originHubCity               String?
  originHubLongitude          Float?
  originHubLatitude           Float?

  sprintName                  String?
  livreurFirstName            String?
  livreurLastName             String?
  sprintGeoLongitude          Float?
  sprintGeoLatitude           Float?

  createdAt                   DateTime @default(now())

  @@index([reportId])
  @@index([shippingWorkflowStatus])
  @@index([dateTimeWhenOrderSent])
  @@index([deliveryTimeStart])
  @@index([sprintName])
  @@index([originHubName])
}

// ─── ONBOARDING ────────────────────────────────────────────────────────────

model Driver {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  phone            String           @unique
  email            String?
  city             String?
  status           String           @default("prospect")
  // "prospect" | "en_cours" | "formation" | "valide" | "actif" | "inactif" | "rejete"
  reliabilityScore Float?
  notes            String?
  onboardingSteps  OnboardingStep[]
  courseProgress   CourseProgress[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model OnboardingStep {
  id          String    @id @default(cuid())
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  step        String
  // "kyc_identity" | "kyc_vehicle" | "contract" | "training" | "equipment"
  status      String    @default("pending")
  // "pending" | "submitted" | "validated" | "rejected"
  documentUrl String?
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([driverId, step])
}

// ─── ACADEMY ────────────────────────────────────────────────────────────────

model Course {
  id          String           @id @default(cuid())
  title       String
  category    String
  description String
  color       String           @default("#2563eb")
  emoji       String           @default("📚")
  order       Int              @default(0)
  lessons     Lesson[]
  progress    CourseProgress[]
  createdAt   DateTime         @default(now())
}

model Lesson {
  id         String         @id @default(cuid())
  courseId   String
  course     Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  type       String         // "video" | "quiz" | "document"
  contentUrl String?
  content    String?
  duration   Int?
  order      Int            @default(0)
  questions  QuizQuestion[]
  createdAt  DateTime       @default(now())
}

model QuizQuestion {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question String
  options  String // JSON array stored as string
  correct  Int
  order    Int    @default(0)
}

model CourseProgress {
  id          String    @id @default(cuid())
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  score       Float?
  certified   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([driverId, courseId])
}

// ─── SPRINT 5 — SCORE IA ─────────────────────────────────────────────────────

model GuideLesson {
  id        String   @id @default(cuid())
  moduleKey String
  title     String
  stepOrder Int
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model GuideFeedback {
  id        String   @id @default(cuid())
  moduleKey String
  helpful   Boolean
  createdAt DateTime @default(now())
}

model ReliabilityScore {
  id              String   @id @default(cuid())
  driverName      String
  deliveryRate    Float    @default(0)
  academyScore    Float    @default(0)
  noShowRate      Float    @default(0)
  score           Float    @default(0)
  // score = deliveryRate*0.4 + academyScore*0.3 + (100-noShowRate)*0.3
  recommendation  String?
  calculatedAt    DateTime @default(now())

  @@index([driverName])
  @@index([calculatedAt])
}

// ─── SPRINT 7 — ALERTES PRÉDICTIVES + SLACK ───────────────────────────────────

model DeliveryAlert {
  id           String    @id @default(cuid())
  orderId      String?
  reportId     String?
  driverName   String?
  mode         String    @default("standard") // "standard" | "express"
  level        Int       @default(1)           // 1=warning 2=danger 3=critical
  type         String    // "delay_risk" | "delay_confirmed" | "gps_blocked" | "predictive"
  message      String
  channel      String    @default("inapp")
  acknowledged Boolean   @default(false)
  triggeredAt  DateTime  @default(now())
  ackAt        DateTime?
  ackBy        String?
  createdAt    DateTime  @default(now())

  @@index([acknowledged])
  @@index([level])
  @@index([createdAt])
}

model SlackConfig {
  id         String   @id @default(cuid())
  webhookUrl String
  channel    String   @default("#alertes-livraison")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── SPRINT 8 — RÉMUNÉRATION LIVREURS ────────────────────────────────────────

model PayConfig {
  id          String   @id @default(cuid())
  mode        String   @default("standard") // "standard" | "express"
  label       String   @default("Standard")
  baseRate    Float    @default(15)  // MAD par livraison réussie
  bonusRate   Float    @default(5)   // MAD bonus livraison dans les délais
  penaltyRate Float    @default(5)   // MAD pénalité par NO_SHOW
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mode])
}

model DriverPay {
  id           String   @id @default(cuid())
  reportId     String
  driverName   String
  mode         String   @default("standard")
  total        Int      @default(0)  // total commandes assignées
  deliveries   Int      @default(0)  // livraisons réussies
  onTime       Int      @default(0)  // dans les délais
  noShows      Int      @default(0)  // NO_SHOW
  grossPay     Float    @default(0)  // deliveries × baseRate
  bonus        Float    @default(0)  // onTime × bonusRate
  penalty      Float    @default(0)  // noShows × penaltyRate
  netPay       Float    @default(0)  // grossPay + bonus - penalty
  calculatedAt DateTime @default(now())

  @@unique([reportId, driverName, mode])
  @@index([reportId])
  @@index([driverName])
}

// ─── SPRINT 9 — DISPATCH + POINTAGE + SUPPORT ────────────────────────────────

model DriverAttendance {
  id         String    @id @default(cuid())
  driverName String
  date       DateTime  // date du jour (minuit UTC)
  hub        String?
  checkIn    DateTime?
  checkOut   DateTime?
  status     String    @default("present") // "present"|"absent"|"late"|"leave"
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([driverName, date])
  @@index([date])
  @@index([driverName])
}

model SupportTicket {
  id          String    @id @default(cuid())
  reference   String    @unique // SUP-0001
  category    String    // "livraison_manquee"|"retard"|"reclamation_cod"|"mauvais_service"|"autre"
  priority    String    @default("normale") // "urgent"|"haute"|"normale"|"basse"
  status      String    @default("ouvert")  // "ouvert"|"en_cours"|"resolu"|"ferme"
  subject     String
  description String
  clientName  String?
  clientPhone String?
  orderRef    String?
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([createdAt])
}
