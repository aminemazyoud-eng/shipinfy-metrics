generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeliveryReport {
  id         String          @id @default(cuid())
  filename   String
  uploadedAt DateTime        @default(now())
  isActive   Boolean         @default(true)
  orders     DeliveryOrder[]
}

model ScheduledReport {
  id           String        @id @default(cuid())
  reportId     String
  emails       String
  frequency    String
  time         String
  dayOfWeek    Int?
  dayOfMonth   Int?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sendLogs     EmailSendLog[]
}

model EmailSendLog {
  id          String          @id @default(cuid())
  scheduleId  String
  schedule    ScheduledReport @relation(fields: [scheduleId], references: [id])
  sentAt      DateTime        @default(now())
  success     Boolean
  recipients  String
  error       String?
}

// ─── ALERTES & TICKETS ─────────────────────────────────────────────────────

model AlertRule {
  id        String   @id @default(cuid())
  name      String
  metric    String   // "delivery_rate" | "no_show_rate" | "on_time_rate" | "no_show_count"
  operator  String   // "lt" | "gt" | "lte" | "gte"
  threshold Float
  severity  String   @default("warning") // "critical" | "warning" | "info"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  alerts    Alert[]
}

model Alert {
  id          String    @id @default(cuid())
  ruleId      String?
  rule        AlertRule? @relation(fields: [ruleId], references: [id])
  type        String    // "auto" | "manual"
  severity    String    // "critical" | "warning" | "info"
  title       String
  description String
  metricValue Float?
  threshold   Float?
  status      String    @default("open") // "open" | "in_progress" | "resolved"
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  tickets     Ticket[]
}

model Ticket {
  id          String          @id @default(cuid())
  alertId     String?
  alert       Alert?          @relation(fields: [alertId], references: [id])
  title       String
  description String
  priority    String          @default("moyenne") // "haute" | "moyenne" | "basse"
  status      String          @default("ouvert") // "ouvert" | "en_cours" | "resolu" | "ferme"
  assignedTo  String?
  comments    TicketComment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    String
  content   String
  createdAt DateTime @default(now())
}

// ─── DELIVERY ORDERS ───────────────────────────────────────────────────────

model DeliveryOrder {
  id                          String         @id @default(cuid())
  reportId                    String
  report                      DeliveryReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  externalReference           String?
  shipperReference            String?
  carrierReference            String?

  pickupTimeStart             DateTime?
  deliveryTimeStart           DateTime?
  deliveryTimeEnd             DateTime?

  dateTimeWhenOrderSent       DateTime?
  dateTimeWhenAssigned        DateTime?
  dateTimeWhenInTransport     DateTime?
  dateTimeWhenStartDelivery   DateTime?
  dateTimeWhenDelivered       DateTime?
  dateTimeWhenNoShow          DateTime?
  dateTimeLastUpdate          DateTime?

  shippingWorkflowStatus      String?
  paymentOnDeliveryAmount     Float?

  destinationFirstname        String?
  destinationLastname         String?
  destinationCityCode         String?
  destinationLongitude        Float?
  destinationLatitude         Float?

  originHubName               String?
  originHubCode               String?
  originHubCity               String?
  originHubLongitude          Float?
  originHubLatitude           Float?

  sprintName                  String?
  livreurFirstName            String?
  livreurLastName             String?
  sprintGeoLongitude          Float?
  sprintGeoLatitude           Float?

  createdAt                   DateTime @default(now())

  @@index([reportId])
  @@index([shippingWorkflowStatus])
  @@index([dateTimeWhenOrderSent])
  @@index([deliveryTimeStart])
  @@index([sprintName])
  @@index([originHubName])
}

// ─── ONBOARDING ────────────────────────────────────────────────────────────

model Driver {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  phone            String           @unique
  email            String?
  city             String?
  status           String           @default("prospect")
  // "prospect" | "en_cours" | "formation" | "valide" | "actif" | "inactif" | "rejete"
  reliabilityScore Float?
  notes            String?
  onboardingSteps  OnboardingStep[]
  courseProgress   CourseProgress[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model OnboardingStep {
  id          String    @id @default(cuid())
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  step        String
  // "kyc_identity" | "kyc_vehicle" | "contract" | "training" | "equipment"
  status      String    @default("pending")
  // "pending" | "submitted" | "validated" | "rejected"
  documentUrl String?
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([driverId, step])
}

// ─── ACADEMY ────────────────────────────────────────────────────────────────

model Course {
  id          String           @id @default(cuid())
  title       String
  category    String
  description String
  color       String           @default("#2563eb")
  emoji       String           @default("📚")
  order       Int              @default(0)
  lessons     Lesson[]
  progress    CourseProgress[]
  createdAt   DateTime         @default(now())
}

model Lesson {
  id         String         @id @default(cuid())
  courseId   String
  course     Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  type       String         // "video" | "quiz" | "document"
  contentUrl String?
  content    String?
  duration   Int?
  order      Int            @default(0)
  questions  QuizQuestion[]
  createdAt  DateTime       @default(now())
}

model QuizQuestion {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question String
  options  String // JSON array stored as string
  correct  Int
  order    Int    @default(0)
}

model CourseProgress {
  id          String    @id @default(cuid())
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  score       Float?
  certified   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([driverId, courseId])
}

// ─── SPRINT 5 — SCORE IA ─────────────────────────────────────────────────────

model ReliabilityScore {
  id              String   @id @default(cuid())
  driverName      String
  deliveryRate    Float    @default(0)
  academyScore    Float    @default(0)
  noShowRate      Float    @default(0)
  score           Float    @default(0)
  // score = deliveryRate*0.4 + academyScore*0.3 + (100-noShowRate)*0.3
  recommendation  String?
  calculatedAt    DateTime @default(now())

  @@index([driverName])
  @@index([calculatedAt])
}
